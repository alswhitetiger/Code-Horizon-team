# PostgreSQL 데이터베이스 URL
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/edulink

# Redis URL
REDIS_URL=redis://localhost:6379

# Anthropic Claude API 키 (https://console.anthropic.com 에서 발급)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# JWT 설정 (최소 32자 랜덤 문자열로 변경)
JWT_SECRET=change-this-to-a-random-32-char-string
JWT_EXPIRE_MINUTES=1440

# 프론트엔드 URL (CORS 허용 도메인)
FRONTEND_URL=http://localhost:3000
